# Home Assistant integration (hidden by default)
# Set to 1 to show the HOME ASST menu entry, load persisted HA config on boot,
# and enable the /ha config page. When unset, HA is fully gated off.
DSKY_HOMEASSISTANT=

# Override the server's advertised base URL (used for QR codes, config links, etc.).
# When set, the menu's NETWORK interface picker is hidden. No trailing slash.
# Example: DSKY_BASE_URL=http://dsky.local:3000
DSKY_BASE_URL=

# Set to 1 to turn off LAN peer discovery. This DSKY will no longer advertise
# itself via Bonjour/mDNS, and it won't see other DSKYs on the network
DSKY_MDNS_DISABLED=

# Home Assistant connection (optional, for development)
# These values pre-fill the config wizard fields.
# In production (on the DSKY device), the user enters them via the config wizard instead.
#
# NOTE: After completing the config wizard, the URL and token are persisted
# to ha_entities.json so the DSKY can auto-connect on reboot.

# Your Home Assistant URL (e.g. http://homeassistant.local:8123)
HA_URL=

# Long-lived access token from Home Assistant
# Generate one at: your-ha-url/profile -> Long-Lived Access Tokens -> Create Token
HA_TOKEN=
